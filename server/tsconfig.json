{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@db/*": ["src/db/*"],
      "@devices/*": ["src/devices/*"],
      "@notifications/*": ["src/notifications/*"],
      "@firebase/*": ["src/firebase/*"],
      "@config/*": ["src/config/*"],
      "@model/*": ["src/db/schema/*"],
      "@topics/*": ["src/topics/*"]
    }
  },
  "include": ["src"]
}
